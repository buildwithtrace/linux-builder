#!/usr/bin/make -f
export DH_VERBOSE = 1

# Ubuntu 25.10+ enables -flto=auto by default via dpkg-buildflags.
# Combined with -fvisibility-inlines-hidden, this causes inline virtual
# destructors from header-only libraries (nlohmann_json) to be discarded
# during the LTO pass, producing undefined reference errors.
# See: https://gitlab.com/kicad/packaging/kicad-ubuntu-builder/kicad-daily-package/-/commit/2028645d
export DEB_BUILD_MAINT_OPTIONS = optimize=-lto

%:
	dh $@ --parallel

override_dh_auto_configure:
	dh_auto_configure -- \
		-G Ninja \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_BUILD_TYPE=RelWithDebInfo \
		-DTRACE_BACKEND_URL="https://api.buildwithtrace.com/api/v3" \
		-DKICAD_USE_OCC=ON \
		-DKICAD_SPICE=ON \
		-DKICAD_BUILD_I18N=ON \
		-DKICAD_USE_CMAKE_FINDPROTOBUF=ON \
		-DKICAD_BUILD_QA_TESTS=OFF

override_dh_auto_test:
	HOME=/tmp dh_auto_test $@

override_dh_strip:
	dh_strip --dbgsym-migration='trace-dbg (<< 1.2.0~)'

override_dh_compress:
	dh_compress -X.py

override_dh_shlibdeps:
	dh_shlibdeps -- \
		-l$(CURDIR)/debian/trace/usr/lib/
